# Odoo Connection
ODOO_URL=https://mi-empresa.odoo.com
ODOO_DB=mi-empresa-produccion
ODOO_USER=usuario@empresa.com
ODOO_API_KEY=tu-api-key-aqui

# ZKTeco Devices (JSON array)
ZKTECO_DEVICES=[{"name":"Oficina Principal","ip":"192.168.1.100","port":4370}]
# Timeout in ms for TCP commands (default 30000). Increase if you see TIMEOUT_IN_RECEIVING_RESPONSE_AFTER_REQUESTING_DATA
# ZKTECO_TIMEOUT_MS=30000

# Sync Settings
SYNC_INTERVAL=*/30 * * * *
ENROLL_INTERVAL=0 8 * * 2
TIMEZONE=America/Mazatlan
# CRON_ENABLED=1   # Set to 0 or false to disable automatic sync and enrollment (health check still runs)

# Dedup y auto-cierre
# DEDUP_MINUTES=10               # Ignorar checada si hay otra del mismo usuario/dispositivo en menos de N min
# STALE_THRESHOLD_HOURS=16       # Si la asistencia abierta tiene mas de N horas, auto-cerrar
# AUTO_CLOSE_HOURS=8             # Cerrar asistencia vieja a check_in + N horas

# Respaldo y sync de huellas
# BACKUP_INTERVAL=0 2 * * 0             # Respaldo incremental de huellas (default: domingos 2am)
# FINGERPRINT_SYNC_INTERVAL=0 3 * * 0   # Sync huellas faltantes a dispositivos (default: domingos 3am)

# TLS (0 para instancias .dev.odoo.com, remover en produccion con dominio propio)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Logging
LOG_LEVEL=info
# Optional: file logging with rotation (e.g. on Raspberry Pi)
# LOG_PATH=/var/log/odoo-checador/app.log
# LOG_MAX_SIZE=10m
# LOG_MAX_FILES=7d

# Health Check
HEALTH_PORT=3000
