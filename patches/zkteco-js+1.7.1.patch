+    /**
+     * Request user template (fingerprint) by uid and finger index.
+     * If the device responds with CMD_PREPARE_DATA (1500), requests data in chunks
+     * and returns the template buffer; otherwise returns the payload of CMD_ACK_OK/CMD_ACK_DATA.
+     * @param {number} uid - User ID on device
+     * @param {number} finger - Finger index (0-9 or 1-10 depending on device)
+     * @returns {Promise<Buffer|null>} Template buffer or null if no template
+     */
+    async getUserTemplateChunked(uid, finger) {
+        const reqData = Buffer.alloc(3);
+        reqData.writeUInt16LE(parseInt(uid, 10), 0);
+        reqData.writeUInt8(finger, 2);
+
+        const rReply = await this.executeCmd(COMMANDS.CMD_USERTEMP_RRQ, reqData);
+        if (!rReply || rReply.length < 8) return null;
+
+        const cmdId = rReply.readUInt16LE(0);
+        if (cmdId === COMMANDS.CMD_ACK_OK || cmdId === COMMANDS.CMD_ACK_DATA) {
+            const data = rReply.slice(8);
+            return data.length > 0 ? data : null;
+        }
+
+        if (cmdId === COMMANDS.CMD_PREPARE_DATA) {
+            const recvData = rReply.slice(8);
+            // Try common offsets for template size (device-dependent)
+            const candidates = [
+                recvData.length >= 4 && recvData.readUIntLE(0, 4),
+                recvData.length >= 5 && recvData.readUIntLE(1, 4),
+                recvData.length >= 8 && recvData.readUIntLE(4, 4),
+                recvData.length >= 2 && recvData.readUInt16LE(0),
+                recvData.length >= 4 && recvData.readUInt16LE(2),
+                recvData.length >= 6 && recvData.readUInt16LE(4),
+                recvData.length >= 8 && recvData.readUInt16LE(6),
+            ].filter((n) => typeof n === 'number' && n >= 32 && n <= 50000);
+            const size = candidates[0] || 0;
+            if (!size) return null;
+
+            let remain = size % MAX_CHUNK;
+            let numberChunks = Math.floor((size - remain) / MAX_CHUNK);
+            let totalPackets = numberChunks + (remain > 0 ? 1 : 0);
+            let replyData = Buffer.from([]);
+            let totalBuffer = Buffer.from([]);
+            let realTotalBuffer = Buffer.from([]);
+            const timeout = 10000;
+
+            return new Promise((resolve, reject) => {
+                let timer = setTimeout(() => {
+                    if (this.socket) this.socket.removeListener('data', handleOnData);
+                    resolve(replyData.length > 0 ? replyData : null);
+                }, timeout);
+
+                const internalCallback = (data, err) => {
+                    clearTimeout(timer);
+                    if (this.socket) this.socket.removeListener('data', handleOnData);
+                    if (err) reject(err);
+                    else resolve(data);
+                };
+
+                const handleOnData = (reply) => {
+                    if (checkNotEventTCP(reply)) return;
+                    clearTimeout(timer);
+                    timer = setTimeout(() => {
+                        internalCallback(replyData, new Error('TIMEOUT_WHEN_RECEIVING_TEMPLATE_CHUNKS'));
+                    }, timeout);
+
+                    totalBuffer = Buffer.concat([totalBuffer, reply]);
+                    if (totalBuffer.length < 8) return;
+                    const packetLength = totalBuffer.readUIntLE(4, 2);
+                    if (totalBuffer.length >= 8 + packetLength) {
+                        realTotalBuffer = Buffer.concat([realTotalBuffer, totalBuffer.subarray(16, 8 + packetLength)]);
+                        totalBuffer = totalBuffer.subarray(8 + packetLength);
+
+                        if ((totalPackets > 1 && realTotalBuffer.length === MAX_CHUNK + 8)
+                            || (totalPackets === 1 && realTotalBuffer.length === remain + 8)) {
+                            replyData = Buffer.concat([replyData, realTotalBuffer.subarray(8)]);
+                            totalBuffer = Buffer.from([]);
+                            realTotalBuffer = Buffer.from([]);
+                            totalPackets -= 1;
+
+                            if (totalPackets <= 0) {
+                                internalCallback(replyData);
+                                return;
+                            }
+                        } else if (totalPackets === 1 && realTotalBuffer.length === remain) {
+                            replyData = Buffer.concat([replyData, realTotalBuffer]);
+                            totalBuffer = Buffer.from([]);
+                            realTotalBuffer = Buffer.from([]);
+                            totalPackets -= 1;
+                            internalCallback(replyData);
+                            return;
+                        }
+                    }
+                };
+
+                this.socket.once('close', () => {
+                    internalCallback(replyData, new Error('Socket closed while receiving template chunks'));
+                });
+
+                this.socket.on('data', handleOnData);
+
+                for (let i = 0; i <= numberChunks; i++) {
+                    if (i === numberChunks) {
+                        if (remain > 0) this.sendChunkRequest(numberChunks * MAX_CHUNK, remain);
+                    } else {
+                        this.sendChunkRequest(i * MAX_CHUNK, MAX_CHUNK);
+                    }
+                }
+            });
+        }
+
+        return null;
+    }
+
 
